APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
BAILIAN_API_KEY=
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tokenmall
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-jwt-secret
JWT_EXPIRE_MINUTES=1440
LITELLM_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-tokenmall-master
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
ADMIN_EMAIL=admin@tokenmall.dev
ADMIN_PASSWORD=Admin123456

# ===== 邮箱配置：邮箱验证码登录 =====
# SMTP 服务器地址，例如 QQ 邮箱为 smtp.qq.com，企业邮箱按服务商文档填写
SMTP_HOST=
# SMTP 端口，465 常用于 SSL，587 常用于 TLS
SMTP_PORT=465
# SMTP 登录账号，通常填写完整邮箱地址
SMTP_USERNAME=
# SMTP 登录密码，很多邮箱服务这里要填“授权码”而不是邮箱登录密码
SMTP_PASSWORD=
# 发件人邮箱，建议与 SMTP_USERNAME 保持一致，避免被服务商拦截
SMTP_FROM_EMAIL=
# 发件人名称，用户在邮件中看到的发件人标题
SMTP_FROM_NAME=TokenMall
# 是否启用 SSL，465 端口通常为 true
SMTP_USE_SSL=true
# 是否启用 TLS，587 端口通常为 true；如果启用了 SSL，这里一般为 false
SMTP_USE_TLS=false

# ===== 阿里云号码认证：短信认证服务 =====
# 阿里云 AccessKey ID
ALIBABA_CLOUD_ACCESS_KEY_ID=
# 阿里云 AccessKey Secret
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# 号码认证服务区域，当前按阿里云官方常见值预填为 cn-hangzhou
ALIBABA_CLOUD_SMS_REGION=cn-hangzhou
# 是否启用阿里云短信认证服务；为 false 时继续使用本地演示验证码逻辑
ALIBABA_CLOUD_SMS_AUTH_ENABLED=false
# 号码认证控制台里选择的签名名称，通常使用赠送签名
ALIBABA_CLOUD_SMS_SIGN_NAME=
# 号码认证控制台里选择的验证码模板 Code
ALIBABA_CLOUD_SMS_TEMPLATE_CODE=
# 模板参数 JSON，变量名必须与你选择的模板一致；使用 ##code## 让阿里云生成并校验验证码
ALIBABA_CLOUD_SMS_TEMPLATE_PARAM={"code":"##code##","min":"5"}
# 可选，短信认证服务方案名；如果你使用默认方案，这里可以留空
ALIBABA_CLOUD_SMS_SCHEME_NAME=
# 调试开关。开发环境可设为 true 以便在支持时返回 demo_code，生产环境建议设为 false
ALIBABA_CLOUD_SMS_DEBUG_RETURN_DEMO_CODE=true

# ===== 支付配置：支付宝 =====
# 支付宝开放平台应用 AppID
ALIPAY_APP_ID=
# 支付宝应用私钥文件绝对路径，例如：/Users/yourname/certs/alipay_private_key.txt
ALIPAY_APP_PRIVATE_KEY_PATH=
# 支付宝公钥文件绝对路径。这里必须填“支付宝公钥”，不要填密钥工具生成的“应用公钥”
# 例如：/Users/yourname/certs/alipay_public_key.txt
ALIPAY_PUBLIC_KEY_PATH=
# 支付宝网关，正式环境默认即可，沙箱可改为沙箱网关
ALIPAY_SERVER_URL=https://openapi.alipay.com/gateway.do
# 支付宝异步回调地址，需要公网可访问，例如：https://your-domain.com/payments/alipay/notify
ALIPAY_NOTIFY_URL=
# 支付宝同步跳转地址，可选，例如：https://your-domain.com/recharge
ALIPAY_RETURN_URL=

# ===== 支付配置：微信支付 =====
# 微信支付 AppID
WECHAT_APP_ID=
# 微信商户号 mchid
WECHAT_MCH_ID=
# 微信商户私钥文件绝对路径，例如：/Users/yourname/certs/apiclient_key.pem
WECHAT_PRIVATE_KEY_PATH=
# 微信商户证书序列号
WECHAT_CERT_SERIAL_NO=
# 微信支付 APIv3 Key
WECHAT_APIV3_KEY=
# 微信支付异步回调地址，需要公网可访问，例如：https://your-domain.com/payments/wechat/notify
WECHAT_NOTIFY_URL=

# 银联商户号，例如：777290058110048
UNIONPAY_MERCHANT_ID=
# 银联签名证书（pfx/p12）绝对路径，例如：/Users/yourname/certs/unionpay_sign.pfx
UNIONPAY_SIGN_CERT_PATH=
# 银联签名证书密码
UNIONPAY_SIGN_CERT_PASSWORD=
# 银联验签证书绝对路径（可选，兼容旧配置）
UNIONPAY_VERIFY_CERT_PATH=
# 银联根证书绝对路径，例如：/Users/yourname/certs/acp_test_root.cer
UNIONPAY_ROOT_CERT_PATH=
# 银联中级证书绝对路径，例如：/Users/yourname/certs/acp_test_middle.cer
UNIONPAY_MIDDLE_CERT_PATH=
# 银联前台回跳地址，例如：https://your-domain.com/recharge
UNIONPAY_FRONT_URL=
# 银联后台通知地址，例如：https://your-domain.com/payments/unionpay/notify
UNIONPAY_BACK_URL=
# 银联前台交易地址，测试环境默认如下
UNIONPAY_FRONT_TRANS_URL=https://gateway.test.95516.com/gateway/api/frontTransReq.do
# 银联后台交易地址，退款等后台交易默认如下
UNIONPAY_BACK_TRANS_URL=https://gateway.test.95516.com/gateway/api/backTransReq.do
# 银联交易查询地址，测试环境默认如下
UNIONPAY_QUERY_URL=https://gateway.test.95516.com/gateway/api/queryTrans.do
